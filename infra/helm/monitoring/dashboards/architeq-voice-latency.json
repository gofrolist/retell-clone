{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Architeq — Voice Latency",
  "uid": "architeq-voice-latency",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["architeq", "latency", "slo"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM TTFB (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(architeq_llm_ttfb_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(architeq_llm_ttfb_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "TTS TTFB (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(architeq_tts_ttfb_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(architeq_tts_ttfb_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "AMD detections by result",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(architeq_amd_detections_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Worker active jobs (per pod)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (architeq_worker_active_jobs)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Agent response p95 (SLO)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 2.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(architeq_llm_ttfb_seconds_bucket[5m]))) + histogram_quantile(0.95, sum by (le) (rate(architeq_tts_ttfb_seconds_bucket[5m])))",
          "legendFormat": "p95 LLM+TTS TTFB"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Worker CPU (per pod)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"architeq\", pod=~\".*worker.*\", container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
