{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Architeq — Calls",
  "uid": "architeq-calls",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["architeq", "calls"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Call rate by direction / status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (direction, status) (rate(architeq_calls_total[5m]))",
          "legendFormat": "{{direction}} / {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Concurrent calls",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(architeq_calls_ongoing)",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Call duration (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(architeq_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(architeq_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(architeq_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Webhook deliveries by event / outcome",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event, outcome) (rate(architeq_webhook_deliveries_total[5m]))",
          "legendFormat": "{{event}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tool calls by tool / outcome",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool, outcome) (rate(architeq_tool_calls_total[5m]))",
          "legendFormat": "{{tool}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Webhook failure ratio",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(architeq_webhook_deliveries_total{outcome!=\"success\"}[5m])) / clamp_min(sum(rate(architeq_webhook_deliveries_total[5m])), 1e-9)",
          "legendFormat": "failure ratio"
        }
      ]
    }
  ]
}
