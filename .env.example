# Local development env — copy to `.env` (gitignored) and fill in the two
# provider keys. `make api` / `make worker` / `make dev` load it automatically.

# LiveKit dev server from docker-compose (--dev mode fixed credentials).
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Worker -> API internal auth. Any non-empty string; both sides read this file.
ARHITEQ_API_URL=http://127.0.0.1:8080
ARHITEQ_INTERNAL_TOKEN=dev-internal-token

# Real provider keys (required by the worker for STT/TTS and the LLM).
CARTESIA_API_KEY=
GOOGLE_API_KEY=
